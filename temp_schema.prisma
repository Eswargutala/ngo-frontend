
//
// GET INVOLVED & PARTNERSHIPS
//

model InternshipApplication {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String
  college        String
  courseYear     String
  areaOfInterest String
  why            String   @db.Text
  experience     String?  @db.Text
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model CampusAmbassadorApplication {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String
  collegeName    String
  courseYear     String
  city           String
  areaOfInterest String?
  why            String   @db.Text
  experience     String?  @db.Text
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model VolunteerApplication {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String
  city           String
  areaOfInterest String
  why            String   @db.Text
  availability   String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model MentorApplication {
  id                String   @id @default(cuid())
  fullName          String
  email             String
  phone             String
  professionCollege String
  areaOfExpertise   String
  experience        String
  whyMentor         String   @db.Text
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
}

model PartnershipRequest {
  id                  String   @id @default(cuid())
  companyName         String
  contactPerson       String
  email               String
  phone               String
  industry            String
  partnershipInterest String
  message             String   @db.Text
  status              String   @default("PENDING")
  createdAt           DateTime @default(now())
}

model WorkshopRequest {
  id               String   @id @default(cuid())
  organizationName String
  contactPerson    String
  email            String
  phone            String
  location         String
  workshopType     String
  participants     String
  preferredDate    String
  message          String?  @db.Text
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
}
